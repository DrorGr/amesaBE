@page "/login"
@inject IAdminSignInService SignInService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager Navigation

<PageTitle>Login - Amesa Admin</PageTitle>

<div class="container">
    <div class="row justify-content-center align-items-center" style="min-height: 100vh;">
        <div class="col-md-5">
            <div class="card shadow-lg">
                <div class="card-body p-5">
                    <div class="text-center mb-4">
                        <i class="fas fa-crown fa-3x text-primary"></i>
                        <h2 class="mt-3">Amesa Admin</h2>
                        <p class="text-muted">Sign in to manage content</p>
                    </div>

                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="alert alert-danger" role="alert">
                            <i class="fas fa-exclamation-triangle"></i> @errorMessage
                        </div>
                    }

                    <form @onsubmit="HandleSubmit" @onsubmit:preventDefault="true">
                        @if (!requiresMfa)
                        {
                            <div class="mb-3">
                                <label for="email" class="form-label">
                                    <i class="fas fa-envelope"></i> Email Address
                                </label>
                                <input type="email" id="email" class="form-control form-control-lg @(emailError ? "is-invalid" : "")" 
                                       value="@email" @oninput="@(e => { email = e.Value?.ToString() ?? ""; emailError = false; })"
                                       placeholder="Enter your email" required autocomplete="email" />
                                @if (emailError)
                                {
                                    <div class="invalid-feedback">Please enter a valid email address.</div>
                                }
                            </div>

                            <div class="mb-4">
                                <label for="password" class="form-label">
                                    <i class="fas fa-lock"></i> Password
                                </label>
                                <input type="password" id="password" class="form-control form-control-lg @(passwordError ? "is-invalid" : "")" 
                                       value="@password" @oninput="@(e => { password = e.Value?.ToString() ?? ""; passwordError = false; })"
                                       placeholder="••••••••" required minlength="8" autocomplete="current-password" />
                                @if (passwordError)
                                {
                                    <div class="invalid-feedback">Password must be at least 8 characters long.</div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-info">
                                Enter the 6-digit code from your authenticator app.
                            </div>
                            <div class="mb-4">
                                <label for="mfaCode" class="form-label">
                                    <i class="fas fa-shield-alt"></i> Verification Code
                                </label>
                                <input type="text" id="mfaCode" class="form-control form-control-lg @(mfaError ? "is-invalid" : "")"
                                       value="@mfaCode" @oninput="@(e => { mfaCode = e.Value?.ToString() ?? ""; mfaError = false; })"
                                       placeholder="123456" inputmode="numeric" autocomplete="one-time-code" />
                                @if (mfaError)
                                {
                                    <div class="invalid-feedback">Please enter a valid verification code.</div>
                                }
                            </div>
                        }

                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary btn-lg" disabled="@isLoading">
                                @if (isLoading)
                                {
                                    <span class="spinner-border spinner-border-sm me-2"></span>
                                    <span>@(requiresMfa ? "Verifying..." : "Signing in...")</span>
                                }
                                else
                                {
                                    <i class="fas fa-sign-in-alt me-2"></i>
                                    <span>@(requiresMfa ? "Verify Code" : "Sign In")</span>
                                }
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private string email = string.Empty;
    private string password = string.Empty;
    private string mfaCode = string.Empty;
    private string? errorMessage;
    private bool isLoading = false;
    private bool requiresMfa = false;
    private bool emailError = false;
    private bool passwordError = false;
    private bool mfaError = false;

    private async Task HandleSubmit()
    {
        if (requiresMfa)
        {
            await HandleMfaVerification();
        }
        else
        {
            await HandleLogin();
        }
    }

    private async Task HandleLogin()
    {
        isLoading = true;
        errorMessage = null;
        emailError = false;
        passwordError = false;
        mfaError = false;

        // Client-side validation
        if (string.IsNullOrWhiteSpace(email))
        {
            emailError = true;
            isLoading = false;
            return;
        }

        if (!IsValidEmail(email))
        {
            emailError = true;
            isLoading = false;
            return;
        }

        if (string.IsNullOrWhiteSpace(password) || password.Length < 8)
        {
            passwordError = true;
            isLoading = false;
            return;
        }

        try
        {
            var result = await SignInService.PasswordSignInAsync(email.Trim(), password);

            if (result.Succeeded)
            {
                CompleteSuccessfulLogin();
            }
            else if (result.RequiresMfa)
            {
                requiresMfa = true;
                password = string.Empty;
            }
            else
            {
                // SECURITY: Generic error message - don't reveal if email exists or account is locked
                errorMessage = "Invalid email or password. Please try again.";
            }
        }
        catch (Exception ex)
        {
            // Log exception for debugging (detailed error is also logged by AdminAuthService)
            // Provide slightly more specific error messages based on exception type
            // while maintaining security (no information leakage)
            var exceptionMessage = ex.Message.ToLower();
            if (exceptionMessage.Contains("database") || exceptionMessage.Contains("dbcontext") || exceptionMessage.Contains("connection"))
            {
                errorMessage = "Authentication service is temporarily unavailable. Please try again later.";
            }
            else if (exceptionMessage.Contains("session") || exceptionMessage.Contains("redis"))
            {
                errorMessage = "Authentication succeeded but session storage failed. Please try again.";
            }
            else
            {
                errorMessage = "An error occurred during login. Please try again.";
            }
            
            // Note: Detailed error is logged by AdminAuthService server-side
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task HandleMfaVerification()
    {
        isLoading = true;
        errorMessage = null;
        mfaError = false;

        if (string.IsNullOrWhiteSpace(mfaCode) || mfaCode.Trim().Length < 6)
        {
            mfaError = true;
            isLoading = false;
            return;
        }

        try
        {
            var result = await SignInService.CompleteMfaSignInAsync(mfaCode);
            if (result.Succeeded)
            {
                CompleteSuccessfulLogin();
            }
            else
            {
                errorMessage = "Invalid verification code. Please try again.";
            }
        }
        catch
        {
            errorMessage = "An error occurred while verifying the code. Please try again.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void CompleteSuccessfulLogin()
    {
        if (AuthenticationStateProvider is AdminAuthenticationStateProvider adminAuthStateProvider)
        {
            adminAuthStateProvider.NotifyAdminAuthenticationStateChanged();
        }

        Navigation.NavigateTo("");
    }

    private bool IsValidEmail(string email)
    {
        try
        {
            var addr = new System.Net.Mail.MailAddress(email);
            return addr.Address == email;
        }
        catch
        {
            return false;
        }
    }
}

