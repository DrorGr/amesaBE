@page "/login"

<PageTitle>Login - Amesa Admin</PageTitle>

<div class="admin-login-page">
<div class="container">
    <div class="row justify-content-center align-items-center" style="min-height: 100vh;">
        <div class="col-md-5">
            <div class="card shadow-lg admin-login-card">
                <div class="card-body p-5">
                    <div class="text-center mb-4">
                        <i class="fas fa-crown fa-3x"></i>
                        <h2 class="mt-3">Amesa Admin</h2>
                        <p class="text-muted">Sign in to manage content</p>
                    </div>

                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="alert alert-danger" role="alert">
                            <i class="fas fa-exclamation-triangle"></i> @errorMessage
                        </div>
                    }

                    <form method="post" action="api/v1/admin/auth/@(requiresMfa ? "mfa" : "login")" onsubmit="return window.setAdminLoginLoading(this);">
                        @if (!requiresMfa)
                        {
                            <div class="mb-3">
                                <label for="email" class="form-label">
                                    <i class="fas fa-envelope"></i> Email Address
                                </label>
                                <input type="email" id="email" name="email" class="form-control form-control-lg" 
                                       placeholder="Enter your email" required autocomplete="email" />
                            </div>

                            <div class="mb-4">
                                <label for="password" class="form-label">
                                    <i class="fas fa-lock"></i> Password
                                </label>
                                <input type="password" id="password" name="password" class="form-control form-control-lg" 
                                       placeholder="••••••••" required minlength="8" autocomplete="current-password" />
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-info">
                                Enter the 6-digit code from your authenticator app.
                            </div>
                            <div class="mb-4">
                                <label for="mfaCode" class="form-label">
                                    <i class="fas fa-shield-alt"></i> Verification Code
                                </label>
                                <input type="text" id="mfaCode" name="code" class="form-control form-control-lg"
                                       placeholder="123456" inputmode="numeric" autocomplete="one-time-code" />
                            </div>
                        }

                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary btn-lg" data-loading-text="@(requiresMfa ? "Verifying..." : "Signing in...")">
                                <span class="spinner-border spinner-border-sm me-2 d-none" aria-hidden="true" data-login-spinner></span>
                                <i class="fas fa-sign-in-alt me-2" data-login-icon></i>
                                <span data-login-text>@(requiresMfa ? "Verify Code" : "Sign In")</span>
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
</div>

<script>
    window.setAdminLoginLoading = function (form) {
        var submitButton = form.querySelector('button[type="submit"]');
        if (!submitButton) {
            return true;
        }

        submitButton.disabled = true;
        submitButton.setAttribute('aria-busy', 'true');

        var spinner = submitButton.querySelector('[data-login-spinner]');
        var icon = submitButton.querySelector('[data-login-icon]');
        var text = submitButton.querySelector('[data-login-text]');

        if (spinner) {
            spinner.classList.remove('d-none');
        }

        if (icon) {
            icon.classList.add('d-none');
        }

        if (text) {
            text.textContent = submitButton.getAttribute('data-loading-text') || 'Signing in...';
        }

        return true;
    };
</script>

@code {
    private string? errorMessage;
    private bool requiresMfa = false;

    [SupplyParameterFromQuery(Name = "error")]
    public string? Error { get; set; }

    [SupplyParameterFromQuery(Name = "mfa")]
    public string? Mfa { get; set; }

    protected override void OnParametersSet()
    {
        requiresMfa = string.Equals(Mfa, "1", StringComparison.OrdinalIgnoreCase);
        errorMessage = Error switch
        {
            "invalid" => "Invalid email or password. Please try again.",
            "mfa" => "Invalid verification code. Please try again.",
            "session" => "Authentication succeeded but session storage failed. Please try again.",
            "unavailable" => "Authentication service is temporarily unavailable. Please try again later.",
            _ => null
        };
    }
}

