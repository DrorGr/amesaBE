@page "/tickets"
@attribute [Authorize(Policy = AdminPermissionNames.TicketsRead)]
@inherits AuthorizedPageBase
@using AmesaBackend.Admin.Services
@using AmesaBackend.Admin.DTOs
@inject ITicketsService TicketsService
@inject IHousesService HousesService
@inject NavigationManager Navigation

<PageTitle>Tickets - Amesa Admin</PageTitle>

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col">
            <h1 class="display-5">
                <i class="fas fa-ticket-alt"></i> Tickets Management
            </h1>
            <p class="text-muted">Monitor per-house ticket inventory, buyer activity, and sell-out timing.</p>
        </div>
    </div>

    <!-- Filters -->
    <div class="card mb-4">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-2">
                    <label class="form-label">House</label>
                    <select class="form-select" @bind="houseIdFilter">
                        <option value="">All Houses</option>
                        @if (houses != null)
                        {
                            @foreach (var house in houses)
                            {
                                <option value="@house.Id">@house.Title</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">User ID</label>
                    <input type="text" class="form-control" @bind="userIdFilter" placeholder="User ID (UUID)" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Status</label>
                    <select class="form-select" @bind="statusFilter">
                        <option value="">All Statuses</option>
                        <option value="Active">Active</option>
                        <option value="Sold">Sold</option>
                        <option value="Cancelled">Cancelled</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Page Size</label>
                    <select class="form-select" @bind="pageSize">
                        <option value="10">10</option>
                        <option value="20">20</option>
                        <option value="50">50</option>
                    </select>
                </div>
                <div class="col-md-3 d-flex align-items-end">
                    <button class="btn btn-secondary w-100" @onclick="LoadTickets">
                        <i class="fas fa-search"></i> Search
                    </button>
                </div>
            </div>
        </div>
    </div>

    @if (houseStats?.Any() == true)
    {
        <div class="row g-3 mb-4">
            @foreach (var stat in houseStats)
            {
                <div class="col-xl-6">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div>
                                    <h5 class="card-title mb-1">@stat.HouseTitle</h5>
                                    <span class="badge bg-@GetHouseStatusBadgeClass(stat.HouseStatus)">@stat.HouseStatus</span>
                                </div>
                                <div class="text-end">
                                    <div class="h4 mb-0">@stat.AvailableTickets</div>
                                    <small class="text-muted">available</small>
                                </div>
                            </div>

                            <div class="progress mb-3" style="height: 10px;">
                                <div class="progress-bar" role="progressbar" style="width: @GetProgressWidth(stat.SoldPercentage)"
                                     aria-valuenow="@stat.SoldPercentage" aria-valuemin="0" aria-valuemax="100"></div>
                            </div>

                            <div class="row g-3">
                                <div class="col-sm-4">
                                    <div class="text-muted small">Bought</div>
                                    <div class="fw-semibold">@stat.BoughtTickets / @stat.TotalTickets</div>
                                    <small class="text-muted">@stat.SoldPercentage.ToString("F2")% sold</small>
                                </div>
                                <div class="col-sm-4">
                                    <div class="text-muted small">Reserved</div>
                                    <div class="fw-semibold">@stat.ReservedTickets</div>
                                    <small class="text-muted">pending checkout</small>
                                </div>
                                <div class="col-sm-4">
                                    <div class="text-muted small">Buyers</div>
                                    <div class="fw-semibold">@stat.UniqueBuyers</div>
                                    <small class="text-muted">@stat.AverageTicketsPerBuyer.ToString("F2") tickets/buyer</small>
                                </div>
                                <div class="col-sm-4">
                                    <div class="text-muted small">Sales Velocity</div>
                                    <div class="fw-semibold">@stat.TicketsPerHour.ToString("F2")/hour</div>
                                    <small class="text-muted">since first ticket</small>
                                </div>
                                <div class="col-sm-4">
                                    <div class="text-muted small">Clock Till Done</div>
                                    <div class="fw-semibold">@FormatDuration(stat.HoursUntilLotteryEnd)</div>
                                    <small class="text-muted">ends @stat.LotteryEndDate.ToString("yyyy-MM-dd HH:mm")</small>
                                </div>
                                <div class="col-sm-4">
                                    <div class="text-muted small">Expected Sell-out</div>
                                    <div class="fw-semibold">@FormatEstimatedSellOut(stat)</div>
                                    <small class="text-muted">@FormatEstimatedSellOutDetail(stat)</small>
                                </div>
                            </div>

                            <div class="border-top mt-3 pt-3 small text-muted">
                                Last ticket: @FormatDateTime(stat.LastTicketPurchasedAt)
                                @if (stat.DrawDate.HasValue)
                                {
                                    <span class="ms-3">Draw: @stat.DrawDate.Value.ToString("yyyy-MM-dd HH:mm")</span>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else if (!isLoading)
    {
        <div class="alert alert-info">
            <i class="fas fa-info-circle"></i> No house ticket statistics found.
        </div>
    }

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else if (tickets?.Items?.Any() == true)
    {
        <div class="card">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Ticket Number</th>
                                <th>House</th>
                                <th>User ID</th>
                                <th>Purchase Price</th>
                                <th>Status</th>
                                <th>Purchase Date</th>
                                <th>Winner</th>
                                <th>Created</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var ticket in tickets.Items)
                            {
                                <tr>
                                    <td><strong>@ticket.TicketNumber</strong></td>
                                    <td>@ticket.HouseTitle</td>
                                    <td>@(ticket.UserId.ToString().Substring(0, 8) + "...")</td>
                                    <td>€@ticket.PurchasePrice.ToString("F2")</td>
                                    <td>
                                        <span class="badge bg-@GetStatusBadgeClass(ticket.Status)">@ticket.Status</span>
                                    </td>
                                    <td>@ticket.PurchaseDate.ToString("yyyy-MM-dd HH:mm")</td>
                                    <td>
                                        @if (ticket.IsWinner)
                                        {
                                            <span class="badge bg-success"><i class="fas fa-trophy"></i> Winner</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td>@ticket.CreatedAt.ToString("yyyy-MM-dd")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Pagination -->
                @if (tickets.TotalPages > 1)
                {
                    <nav>
                        <ul class="pagination justify-content-center">
                            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                <button class="page-link" @onclick="() => ChangePage(currentPage - 1)">Previous</button>
                            </li>
                            @for (int i = 1; i <= tickets.TotalPages; i++)
                            {
                                <li class="page-item @(i == currentPage ? "active" : "")">
                                    <button class="page-link" @onclick="() => ChangePage(i)">@i</button>
                                </li>
                            }
                            <li class="page-item @(currentPage == tickets.TotalPages ? "disabled" : "")">
                                <button class="page-link" @onclick="() => ChangePage(currentPage + 1)">Next</button>
                            </li>
                        </ul>
                    </nav>
                }

                <div class="text-muted text-center mt-3">
                    Showing @((currentPage - 1) * pageSize + 1) to @(Math.Min(currentPage * pageSize, tickets.TotalCount)) of @tickets.TotalCount tickets
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <i class="fas fa-info-circle"></i> No purchased tickets found.
        </div>
    }
</div>

@code {
    private PagedResult<TicketDto>? tickets;
    private List<HouseTicketStatsDto>? houseStats;
    private List<HouseDto>? houses;
    private bool isLoading = true;
    private int currentPage = 1;
    private int pageSize = 20;
    private string? statusFilter;
    private Guid? houseIdFilter;
    private string? userIdFilter;

    protected override async Task OnInitializedAsync()
    {
        await LoadHouses();
        await LoadTickets();
    }

    private async Task LoadHouses()
    {
        try
        {
            var housesResult = await HousesService.GetHousesAsync(1, 1000); // Get all houses for dropdown
            houses = housesResult.Items.ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading houses: {ex.Message}");
        }
    }

    private async Task LoadTickets()
    {
        isLoading = true;
        try
        {
            Guid? userId = null;
            if (!string.IsNullOrWhiteSpace(userIdFilter) && Guid.TryParse(userIdFilter, out var parsedUserId))
            {
                userId = parsedUserId;
            }

            houseStats = await TicketsService.GetHouseTicketStatsAsync(houseIdFilter);
            tickets = await TicketsService.GetTicketsAsync(currentPage, pageSize, houseIdFilter, userId, statusFilter);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading tickets: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ChangePage(int page)
    {
        currentPage = page;
        await LoadTickets();
    }

    private string GetStatusBadgeClass(string status)
    {
        return status switch
        {
            "Active" => "success",
            "Sold" => "primary",
            "Cancelled" => "danger",
            _ => "secondary"
        };
    }

    private string GetHouseStatusBadgeClass(string status)
    {
        return status switch
        {
            "Active" => "success",
            "Upcoming" => "info",
            "Pending" => "warning",
            "Completed" => "secondary",
            "Cancelled" => "danger",
            _ => "secondary"
        };
    }

    private static string GetProgressWidth(decimal percentage)
    {
        return $"{Math.Clamp(percentage, 0, 100):F2}%";
    }

    private static string FormatDuration(double? hours)
    {
        if (!hours.HasValue)
        {
            return "-";
        }

        if (hours.Value <= 0)
        {
            return "Ended";
        }

        var time = TimeSpan.FromHours(hours.Value);
        if (time.TotalDays >= 1)
        {
            return $"{(int)time.TotalDays}d {time.Hours}h";
        }

        return $"{time.Hours}h {time.Minutes}m";
    }

    private static string FormatEstimatedSellOut(HouseTicketStatsDto stat)
    {
        if (stat.IsSoldOut)
        {
            return "Sold out";
        }

        if (!stat.EstimatedSoldOutAt.HasValue)
        {
            return "Not enough data";
        }

        return stat.EstimatedSoldOutAt.Value.ToString("yyyy-MM-dd HH:mm");
    }

    private static string FormatEstimatedSellOutDetail(HouseTicketStatsDto stat)
    {
        if (stat.IsSoldOut)
        {
            return "all tickets bought or reserved";
        }

        if (!stat.HoursToSellOut.HasValue)
        {
            return "waiting for first purchases";
        }

        return $"in {FormatDuration(stat.HoursToSellOut)}";
    }

    private static string FormatDateTime(DateTime? value)
    {
        return value.HasValue ? value.Value.ToString("yyyy-MM-dd HH:mm") : "No purchases yet";
    }
}
