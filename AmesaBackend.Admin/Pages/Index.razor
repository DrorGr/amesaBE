@page "/"
@page "/dashboard"
@attribute [Authorize(Policy = AdminPermissionNames.DashboardRead)]
@inherits AuthorizedPageBase
@using AmesaBackend.Admin.Models
@inject IAdminDatabaseService DatabaseService
@inject IDashboardService DashboardService
@inject IDashboardHealthService DashboardHealthService

<PageTitle>Dashboard - Amesa Admin</PageTitle>

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col">
            <h1 class="admin-page-title">
                <i class="fas fa-tachometer-alt"></i> Dashboard
            </h1>
            <p class="admin-page-subtitle">Welcome to the Amesa Admin Panel</p>
        </div>
    </div>

    <div class="alert alert-info mb-4 admin-env-banner">
        <i class="fas fa-database"></i>
        <strong>Current Environment:</strong> @DatabaseService.GetCurrentEnvironment()
        @if (healthOverview != null)
        {
            <span class="ms-2 text-muted">| Health checked @healthOverview.CheckedAtUtc.ToString("HH:mm:ss") UTC</span>
        }
    </div>

    @if (isHealthLoading)
    {
        <div class="card mb-4 admin-health-panel">
            <div class="card-body text-center py-4">
                <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
                <span class="ms-2 text-muted">Loading system health...</span>
            </div>
        </div>
    }
    else if (healthOverview != null)
    {
        <div class="row g-4 mb-4 admin-health-panel">
            <div class="col-lg-4">
                <div class="card h-100 admin-presence-card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <strong><i class="fas fa-users me-2"></i>Live Presence</strong>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="RefreshHealthAsync" disabled="@isRefreshingHealth">
                            <i class="fas fa-sync @(isRefreshingHealth ? "fa-spin" : "")"></i>
                        </button>
                    </div>
                    <div class="card-body">
                        <p class="small text-muted mb-3">Active in the last @healthOverview.Presence.PresenceWindowMinutes minutes</p>
                        <div class="row g-3 text-center">
                            <div class="col-6">
                                <div class="display-6">@healthOverview.Presence.LoggedInUsers</div>
                                <div class="small text-muted">Logged-in users</div>
                                <div class="small text-muted">@healthOverview.Presence.LoggedInSessions sessions</div>
                            </div>
                            <div class="col-6">
                                <div class="display-6">@healthOverview.Presence.GuestSessions</div>
                                <div class="small text-muted">Guest / anonymous</div>
                                <div class="small text-muted">@healthOverview.Presence.AdminSessionsOnline admin online</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="card h-100">
                    <div class="card-header"><strong><i class="fas fa-server me-2"></i>Services</strong></div>
                    <div class="card-body p-0">
                        <ul class="list-group list-group-flush">
                            @foreach (var item in healthOverview.Services)
                            {
                                <li class="list-group-item d-flex align-items-center justify-content-between gap-2 py-2">
                                    <div class="d-flex align-items-center gap-2 min-w-0">
                                        <span class="health-status-dot @GetHealthDotClass(item.Status)"></span>
                                        <span class="text-truncate">@item.Name</span>
                                    </div>
                                    <small class="text-muted text-nowrap">
                                        @(item.ResponseTimeMs.HasValue ? $"{item.ResponseTimeMs}ms" : item.Detail ?? item.Status)
                                    </small>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="card h-100">
                    <div class="card-header"><strong><i class="fas fa-store me-2"></i>Products</strong></div>
                    <div class="card-body p-0">
                        @if (healthOverview.Products.Any())
                        {
                            <ul class="list-group list-group-flush">
                                @foreach (var item in healthOverview.Products)
                                {
                                    <li class="list-group-item d-flex align-items-center justify-content-between gap-2 py-2">
                                        <div class="d-flex align-items-center gap-2 min-w-0">
                                            <span class="health-status-dot @GetHealthDotClass(item.Status)"></span>
                                            <span class="text-truncate">@item.Name</span>
                                        </div>
                                        <small class="text-muted text-nowrap">
                                            @(item.IsConfigured ? (item.ResponseTimeMs.HasValue ? $"{item.ResponseTimeMs}ms" : item.Detail ?? item.Status) : "Not configured")
                                        </small>
                                    </li>
                                }
                            </ul>
                        }
                        else
                        {
                            <p class="text-muted small p-3 mb-0">No product endpoints configured.</p>
                        }
                    </div>
                </div>
            </div>
        </div>
    }

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4">
            <!-- User Statistics -->
            <div class="col-md-3">
                <div class="card admin-stat-card border-primary">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="text-muted mb-1">Total Users</h6>
                                <h3 class="mb-0">@stats.TotalUsers</h3>
                                <small class="text-success">
                                    <i class="fas fa-arrow-up"></i> @stats.NewUsersToday today
                                </small>
                            </div>
                            <i class="fas fa-users fa-2x text-primary"></i>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card admin-stat-card border-success">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="text-muted mb-1">Active Users</h6>
                                <h3 class="mb-0">@stats.ActiveUsers</h3>
                                <small class="text-muted">@stats.NewUsersThisWeek this week</small>
                            </div>
                            <i class="fas fa-user-check fa-2x text-success"></i>
                        </div>
                    </div>
                </div>
            </div>

            <!-- House Statistics -->
            <div class="col-md-3">
                <div class="card admin-stat-card border-info">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="text-muted mb-1">Total Houses</h6>
                                <h3 class="mb-0">@stats.TotalHouses</h3>
                                <small class="text-info">@stats.ActiveHouses active</small>
                            </div>
                            <i class="fas fa-home fa-2x text-info"></i>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card admin-stat-card border-warning">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="text-muted mb-1">Pending Houses</h6>
                                <h3 class="mb-0">@stats.PendingHouses</h3>
                                <small class="text-warning">Requires review</small>
                            </div>
                            <i class="fas fa-clock fa-2x text-warning"></i>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Ticket Statistics -->
            <div class="col-md-3">
                <div class="card admin-stat-card border-secondary">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="text-muted mb-1">Total Tickets</h6>
                                <h3 class="mb-0">@stats.TotalTickets</h3>
                                <small class="text-success">
                                    <i class="fas fa-arrow-up"></i> @stats.SoldTicketsToday today
                                </small>
                            </div>
                            <i class="fas fa-ticket-alt fa-2x text-secondary"></i>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card admin-stat-card border-success">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="text-muted mb-1">Tickets This Week</h6>
                                <h3 class="mb-0">@stats.SoldTicketsThisWeek</h3>
                                <small class="text-muted">Sold tickets</small>
                            </div>
                            <i class="fas fa-chart-line fa-2x text-success"></i>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Revenue Statistics -->
            <div class="col-md-3">
                <div class="card admin-stat-card border-success">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="text-muted mb-1">Total Revenue</h6>
                                <h3 class="mb-0">€@stats.TotalRevenue.ToString("N2")</h3>
                                <small class="text-success">
                                    <i class="fas fa-arrow-up"></i> €@stats.RevenueToday.ToString("N2") today
                                </small>
                            </div>
                            <i class="fas fa-euro-sign fa-2x text-success"></i>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card admin-stat-card border-primary">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="text-muted mb-1">Revenue This Week</h6>
                                <h3 class="mb-0">€@stats.RevenueThisWeek.ToString("N2")</h3>
                                <small class="text-muted">@stats.TotalTransactions transactions</small>
                            </div>
                            <i class="fas fa-chart-bar fa-2x text-primary"></i>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Draw Statistics -->
            <div class="col-md-3">
                <div class="card admin-stat-card border-info">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="text-muted mb-1">Total Draws</h6>
                                <h3 class="mb-0">@stats.TotalDraws</h3>
                                <small class="text-success">@stats.CompletedDraws completed</small>
                            </div>
                            <i class="fas fa-dice fa-2x text-info"></i>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card admin-stat-card border-warning">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="text-muted mb-1">Pending Draws</h6>
                                <h3 class="mb-0">@stats.PendingDraws</h3>
                                <small class="text-warning">Requires action</small>
                            </div>
                            <i class="fas fa-hourglass-half fa-2x text-warning"></i>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Reservation Statistics -->
            <div class="col-md-3">
                <div class="card admin-stat-card border-primary">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="text-muted mb-1">Active Reservations</h6>
                                <h3 class="mb-0">@stats.ActiveReservations</h3>
                                <small class="text-danger">@stats.ExpiredReservations expired</small>
                            </div>
                            <i class="fas fa-bookmark fa-2x text-primary"></i>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card admin-stat-card border-danger">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="text-muted mb-1">Pending Transactions</h6>
                                <h3 class="mb-0">@stats.PendingTransactions</h3>
                                <small class="text-warning">Requires review</small>
                            </div>
                            <i class="fas fa-exclamation-triangle fa-2x text-danger"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private DashboardStats stats = new();
    private DashboardHealthOverview? healthOverview;
    private bool isLoading = true;
    private bool isHealthLoading = true;
    private bool isRefreshingHealth;

    protected override async Task OnInitializedAsync()
    {
        var statsTask = LoadStatsAsync();
        var healthTask = LoadHealthAsync();
        await Task.WhenAll(statsTask, healthTask);
    }

    private async Task LoadStatsAsync()
    {
        isLoading = true;
        try
        {
            stats = await DashboardService.GetDashboardStatsAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading dashboard stats: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadHealthAsync()
    {
        isHealthLoading = true;
        try
        {
            healthOverview = await DashboardHealthService.GetHealthOverviewAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading dashboard health: {ex.Message}");
        }
        finally
        {
            isHealthLoading = false;
        }
    }

    private async Task RefreshHealthAsync()
    {
        isRefreshingHealth = true;
        try
        {
            await LoadHealthAsync();
        }
        finally
        {
            isRefreshingHealth = false;
        }
    }

    private static string GetHealthDotClass(string status) => status.ToLowerInvariant() switch
    {
        "healthy" => "health-status-healthy",
        "degraded" => "health-status-degraded",
        "unhealthy" => "health-status-unhealthy",
        "skipped" => "health-status-skipped",
        _ => "health-status-unknown"
    };
}


