@page "/draws"
@attribute [Authorize(Policy = AdminPermissionNames.DrawsRead)]
@inherits AuthorizedPageBase
@using AmesaBackend.Admin.Services
@using AmesaBackend.Admin.DTOs
@inject IDrawsService DrawsService
@inject IHousesService HousesService
@inject IAdminPermissionService PermissionService
<PageTitle>Draws - Amesa Admin</PageTitle>

<div class="container-fluid">
    <PageAlert Message="@pageAlertMessage" Type="@pageAlertType" OnDismiss="ClearPageAlert" />

    <header class="admin-page-header row align-items-center">
        <div class="col">
            <h1 class="admin-page-title">
                <i class="fas fa-dice"></i> Draws Management
            </h1>
            <p class="admin-page-subtitle">View and conduct lottery draws</p>
        </div>
        <div class="col-auto">
            <AuthorizeView Policy="@AdminPermissionNames.DrawsConduct">
                <Authorized>
                    <button class="btn btn-primary" @onclick="ShowCreateDrawModal">
                        <i class="fas fa-plus"></i> New Draw
                    </button>
                </Authorized>
            </AuthorizeView>
        </div>
    </header>

    <!-- Filters -->
    <div class="card mb-4">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label">House</label>
                    <select class="form-select" @bind="houseIdFilter">
                        <option value="">All Houses</option>
                        @if (houses != null)
                        {
                            @foreach (var house in houses)
                            {
                                <option value="@house.Id">@house.Title</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Status</label>
                    <select class="form-select" @bind="statusFilter">
                        <option value="">All Statuses</option>
                        <option value="Pending">Pending</option>
                        <option value="Completed">Completed</option>
                        <option value="Cancelled">Cancelled</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Page Size</label>
                    <select class="form-select" @bind="pageSize">
                        <option value="10">10</option>
                        <option value="20">20</option>
                        <option value="50">50</option>
                    </select>
                </div>
                <div class="col-md-3 d-flex align-items-end">
                    <button class="btn btn-secondary w-100" @onclick="LoadDraws">
                        <i class="fas fa-search"></i> Search
                    </button>
                </div>
            </div>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else if (draws?.Items?.Any() == true)
    {
        <div class="card">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>House</th>
                                <th>Draw Date</th>
                                <th>Tickets Sold</th>
                                <th>Participation %</th>
                                <th>Winning Ticket</th>
                                <th>Winner User ID</th>
                                <th>Status</th>
                                <th>Method</th>
                                <th>Conducted At</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var draw in draws.Items)
                            {
                                <tr>
                                    <td><strong>@draw.HouseTitle</strong></td>
                                    <td>@draw.DrawDate.ToString("yyyy-MM-dd HH:mm")</td>
                                    <td>@draw.TotalTicketsSold</td>
                                    <td>@draw.TotalParticipationPercentage.ToString("F2")%</td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(draw.WinningTicketNumber))
                                        {
                                            <span class="badge bg-success">@draw.WinningTicketNumber</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td>
                                        @if (draw.WinnerUserId.HasValue)
                                        {
                                            @(draw.WinnerUserId.Value.ToString().Substring(0, 8) + "...")
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td>
                                        <StatusBadge Value="@draw.DrawStatus" Style="StatusBadgeStyle.Draw" />
                                    </td>
                                    <td>@draw.DrawMethod</td>
                                    <td>
                                        @if (draw.ConductedAt.HasValue)
                                        {
                                            @draw.ConductedAt.Value.ToString("yyyy-MM-dd HH:mm")
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td>
                                        @if (draw.DrawStatus == "Pending")
                                        {
                                            <AuthorizeView Policy="@AdminPermissionNames.DrawsConduct">
                                                <Authorized>
                                                    <button class="btn btn-sm btn-outline-secondary me-1" @onclick="() => ShowRescheduleModal(draw)" title="Reschedule">
                                                        <i class="fas fa-calendar-alt"></i>
                                                    </button>
                                                    <button class="btn btn-sm btn-outline-danger me-1" @onclick="() => ShowCancelDrawModal(draw.Id, draw.HouseTitle)" title="Cancel">
                                                        <i class="fas fa-ban"></i>
                                                    </button>
                                                    <button class="btn btn-sm btn-primary" @onclick="() => ShowConductDrawModal(draw.Id, draw.HouseTitle)" title="Conduct Draw">
                                                        <i class="fas fa-dice"></i> Conduct
                                                    </button>
                                                </Authorized>
                                            </AuthorizeView>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Pagination -->
                @if (draws.TotalPages > 1)
                {
                    <nav>
                        <ul class="pagination justify-content-center">
                            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                <button class="page-link" @onclick="() => ChangePage(currentPage - 1)">Previous</button>
                            </li>
                            @for (int i = 1; i <= draws.TotalPages; i++)
                            {
                                <li class="page-item @(i == currentPage ? "active" : "")">
                                    <button class="page-link" @onclick="() => ChangePage(i)">@i</button>
                                </li>
                            }
                            <li class="page-item @(currentPage == draws.TotalPages ? "disabled" : "")">
                                <button class="page-link" @onclick="() => ChangePage(currentPage + 1)">Next</button>
                            </li>
                        </ul>
                    </nav>
                }

                <div class="text-muted text-center mt-3">
                    Showing @((currentPage - 1) * pageSize + 1) to @(Math.Min(currentPage * pageSize, draws.TotalCount)) of @draws.TotalCount draws
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <i class="fas fa-info-circle"></i> No draws found.
        </div>
    }
</div>

<!-- Conduct Draw Modal -->
@if (showConductModal)
{
    <div class="modal fade show" style="display: block;" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Conduct Draw</h5>
                    <button type="button" class="btn-close" @onclick="CloseConductDrawModal"></button>
                </div>
                <div class="modal-body">
                    <p>Are you sure you want to conduct the draw for <strong>@conductDrawHouseTitle</strong>?</p>
                    <p class="text-muted">This action cannot be undone.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseConductDrawModal">Cancel</button>
                    <button type="button" class="btn btn-primary" @onclick="ConfirmConductDraw" disabled="@isConducting">
                        @if (isConducting)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        Conduct Draw
                    </button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

<!-- Reschedule Draw Modal -->
@if (showRescheduleModal)
{
    <div class="modal fade show" style="display: block;" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Reschedule Draw</h5>
                    <button type="button" class="btn-close" @onclick="CloseRescheduleModal"></button>
                </div>
                <div class="modal-body">
                    @if (!string.IsNullOrWhiteSpace(rescheduleError))
                    {
                        <div class="alert alert-danger">@rescheduleError</div>
                    }
                    <p>Reschedule draw for <strong>@rescheduleHouseTitle</strong></p>
                    <label class="form-label">New Draw Date</label>
                    <input type="datetime-local" class="form-control" @bind="rescheduleDrawDate" />
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseRescheduleModal">Cancel</button>
                    <button type="button" class="btn btn-primary" @onclick="ConfirmRescheduleDraw" disabled="@isRescheduling">
                        @if (isRescheduling)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        Save
                    </button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

<!-- Cancel Draw Modal -->
@if (showCancelModal)
{
    <div class="modal fade show" style="display: block;" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Cancel Draw</h5>
                    <button type="button" class="btn-close" @onclick="CloseCancelDrawModal"></button>
                </div>
                <div class="modal-body">
                    <p>Cancel the pending draw for <strong>@cancelDrawHouseTitle</strong>?</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseCancelDrawModal">Keep</button>
                    <button type="button" class="btn btn-danger" @onclick="ConfirmCancelDraw" disabled="@isCancelling">
                        @if (isCancelling)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        Cancel Draw
                    </button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

<!-- Create Draw Modal -->
@if (showCreateModal)
{
    <div class="modal fade show" style="display: block;" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">New Draw</h5>
                    <button type="button" class="btn-close" @onclick="CloseCreateDrawModal"></button>
                </div>
                <div class="modal-body">
                    @if (!string.IsNullOrWhiteSpace(createError))
                    {
                        <div class="alert alert-danger">@createError</div>
                    }
                    <div class="mb-3">
                        <label class="form-label">House</label>
                        <select class="form-select" @bind="createHouseId">
                            <option value="">Select House</option>
                            @if (houses != null)
                            {
                                @foreach (var house in houses)
                                {
                                    <option value="@house.Id">@house.Title</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Draw Date</label>
                        <input type="datetime-local" class="form-control" @bind="createDrawDate" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseCreateDrawModal">Cancel</button>
                    <button type="button" class="btn btn-primary" @onclick="CreateDraw" disabled="@isCreatingDraw">
                        @if (isCreatingDraw)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        Create Draw
                    </button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

@code {
    private PagedResult<DrawDto>? draws;
    private List<HouseDto>? houses;
    private bool isLoading = true;
    private int currentPage = 1;
    private int pageSize = 20;
    private string? statusFilter;
    private string? houseIdFilter;
    private Guid? selectedDrawId;
    private string conductDrawHouseTitle = string.Empty;
    private bool showConductModal = false;
    private bool isConducting = false;
    private bool showCreateModal = false;
    private bool isCreatingDraw = false;
    private string? createHouseId;
    private DateTime createDrawDate = DateTime.UtcNow.AddDays(1);
    private string? createError;
    private bool showRescheduleModal;
    private bool showCancelModal;
    private bool isRescheduling;
    private bool isCancelling;
    private Guid? rescheduleDrawId;
    private string rescheduleHouseTitle = string.Empty;
    private DateTime rescheduleDrawDate = DateTime.UtcNow.AddDays(1);
    private string? rescheduleError;
    private string cancelDrawHouseTitle = string.Empty;
    private string? pageAlertMessage;
    private string pageAlertType = "info";

    protected override async Task OnInitializedAsync()
    {
        await LoadHouses();
        await LoadDraws();
    }

    private async Task LoadHouses()
    {
        try
        {
            var housesResult = await HousesService.GetHousesAsync(1, 1000, null, null); // Get all houses for dropdown
            houses = housesResult.Items.ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading houses: {ex.Message}");
        }
    }

    private async Task LoadDraws()
    {
        isLoading = true;
        try
        {
            Guid? houseId = string.IsNullOrWhiteSpace(houseIdFilter) ? null : Guid.Parse(houseIdFilter);
            draws = await DrawsService.GetDrawsAsync(currentPage, pageSize, houseId, statusFilter);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading draws: {ex.Message}");
            SetPageAlert($"Error loading draws: {ex.Message}", "danger");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ChangePage(int page)
    {
        currentPage = page;
        await LoadDraws();
    }

    private void SetPageAlert(string message, string type)
    {
        pageAlertMessage = message;
        pageAlertType = type;
    }

    private void ClearPageAlert() => pageAlertMessage = null;

    private void ShowConductDrawModal(Guid drawId, string houseTitle)
    {
        selectedDrawId = drawId;
        conductDrawHouseTitle = houseTitle;
        showConductModal = true;
    }

    private void CloseConductDrawModal()
    {
        showConductModal = false;
        selectedDrawId = null;
        conductDrawHouseTitle = string.Empty;
    }

    private void ShowRescheduleModal(DrawDto draw)
    {
        rescheduleDrawId = draw.Id;
        rescheduleHouseTitle = draw.HouseTitle;
        rescheduleDrawDate = draw.DrawDate;
        rescheduleError = null;
        showRescheduleModal = true;
    }

    private void CloseRescheduleModal()
    {
        showRescheduleModal = false;
        rescheduleDrawId = null;
        rescheduleHouseTitle = string.Empty;
        rescheduleError = null;
    }

    private async Task ConfirmRescheduleDraw()
    {
        if (!rescheduleDrawId.HasValue)
        {
            return;
        }

        isRescheduling = true;
        rescheduleError = null;
        try
        {
            await DrawsService.UpdateDrawScheduleAsync(rescheduleDrawId.Value, new UpdateDrawScheduleRequest
            {
                DrawDate = rescheduleDrawDate
            });
            CloseRescheduleModal();
            await LoadDraws();
        }
        catch (Exception ex)
        {
            rescheduleError = ex.Message;
        }
        finally
        {
            isRescheduling = false;
        }
    }

    private void ShowCancelDrawModal(Guid drawId, string houseTitle)
    {
        selectedDrawId = drawId;
        cancelDrawHouseTitle = houseTitle;
        showCancelModal = true;
    }

    private void CloseCancelDrawModal()
    {
        showCancelModal = false;
        selectedDrawId = null;
        cancelDrawHouseTitle = string.Empty;
    }

    private async Task ConfirmCancelDraw()
    {
        if (!selectedDrawId.HasValue)
        {
            return;
        }

        isCancelling = true;
        try
        {
            await DrawsService.CancelDrawAsync(selectedDrawId.Value);
            CloseCancelDrawModal();
            await LoadDraws();
        }
        catch (Exception ex)
        {
            SetPageAlert($"Error cancelling draw: {ex.Message}", "danger");
        }
        finally
        {
            isCancelling = false;
        }
    }

    private void ShowCreateDrawModal()
    {
        createHouseId = null;
        createDrawDate = DateTime.UtcNow.AddDays(1);
        createError = null;
        showCreateModal = true;
    }

    private void CloseCreateDrawModal()
    {
        showCreateModal = false;
        createError = null;
    }

    private async Task CreateDraw()
    {
        isCreatingDraw = true;
        createError = null;
        try
        {
            if (string.IsNullOrWhiteSpace(createHouseId) || !Guid.TryParse(createHouseId, out var houseId))
            {
                throw new InvalidOperationException("Select a house.");
            }

            await DrawsService.CreateDrawAsync(new CreateDrawRequest
            {
                HouseId = houseId,
                DrawDate = createDrawDate
            });

            CloseCreateDrawModal();
            await LoadDraws();
        }
        catch (Exception ex)
        {
            createError = ex.Message;
        }
        finally
        {
            isCreatingDraw = false;
        }
    }

    private async Task ConfirmConductDraw()
    {
        if (!selectedDrawId.HasValue) return;

        isConducting = true;
        try
        {
            var conductedBy = await PermissionService.GetCurrentAdminUserIdAsync() ?? Guid.Empty;
            
            await DrawsService.ConductDrawAsync(selectedDrawId.Value, conductedBy);
            SetPageAlert("Draw conducted successfully!", "success");
            CloseConductDrawModal();
            await LoadDraws(); // Refresh the list
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error conducting draw: {ex.Message}");
            SetPageAlert($"Error conducting draw: {ex.Message}", "danger");
        }
        finally
        {
            isConducting = false;
        }
    }
}
