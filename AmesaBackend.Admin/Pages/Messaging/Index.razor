@page "/messaging"
@inherits AuthorizedPageBase
@using AmesaBackend.Admin.DTOs
@using AmesaBackend.Admin.Services
@inject IMessagingAdminService MessagingService
@inject IHousesService HousesService
@inject IAdminPermissionService PermissionService

<PageTitle>Messaging - Amesa Admin</PageTitle>

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col">
            <h1 class="display-5">
                <i class="fas fa-bullhorn"></i> Messaging
            </h1>
            <p class="text-muted">Send targeted in-app, email, SMS, push, web push, and Telegram notifications.</p>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(message))
    {
        <div class="alert alert-@messageType">@message</div>
    }

    <div class="card mb-4">
        <div class="card-header">
            <strong>Send Notification</strong>
        </div>
        <div class="card-body">
            @if (!canSendNotifications)
            {
                <div class="alert alert-warning">
                    You can review recent notifications, but sending requires notification send or settings management access.
                </div>
            }
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Target</label>
                    <select class="form-select" @bind="sendRequest.TargetMode">
                        <option value="user">Single User</option>
                        <option value="group">Group</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Type</label>
                    <select class="form-select" @bind="sendRequest.Type">
                        <option value="system_announcement">System Announcement</option>
                        <option value="promotion_created">Promotion</option>
                        <option value="lottery_draw_starting">Lottery Draw Starting</option>
                        <option value="payment_completed">Payment</option>
                        <option value="suspicious_activity">Security</option>
                    </select>
                </div>
                <div class="col-md-5">
                    <label class="form-label">Title</label>
                    <input class="form-control" @bind="sendRequest.Title" />
                </div>
                @if (sendRequest.TargetMode == "user")
                {
                    <div class="col-md-4">
                        <label class="form-label">User ID or Email</label>
                        <input class="form-control" @bind="sendRequest.UserLookup" placeholder="user@example.com or UUID" />
                    </div>
                }
                else
                {
                    <div class="col-md-3">
                        <label class="form-label">Group Basis</label>
                        <select class="form-select" @bind="sendRequest.GroupBasis">
                            <option value="house">Same House</option>
                            <option value="lottery">Same Lottery</option>
                            <option value="birthday">Birthday</option>
                            <option value="location">Location</option>
                            <option value="language">Language</option>
                        </select>
                    </div>

                    @if (sendRequest.GroupBasis == "house")
                    {
                        <div class="col-md-5">
                            <label class="form-label">House</label>
                            <select class="form-select" @bind="houseTargetId">
                                <option value="">Select House</option>
                                @foreach (var house in houses)
                                {
                                    <option value="@house.Id">@house.Title</option>
                                }
                            </select>
                            <div class="form-text">Targets users who bought tickets for this house.</div>
                        </div>
                    }
                    else if (sendRequest.GroupBasis == "lottery")
                    {
                        <div class="col-md-5">
                            <label class="form-label">Lottery House</label>
                            <select class="form-select" @bind="lotteryTargetId">
                                <option value="">Select House</option>
                                @foreach (var house in houses)
                                {
                                    <option value="@house.Id">@house.Title</option>
                                }
                            </select>
                            <div class="form-text">Targets users participating in this lottery.</div>
                        </div>
                    }
                    else if (sendRequest.GroupBasis == "birthday")
                    {
                        <div class="col-md-2">
                            <label class="form-label">Month</label>
                            <input type="number" min="1" max="12" class="form-control" @bind="sendRequest.BirthdayMonth" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Day</label>
                            <input type="number" min="1" max="31" class="form-control" @bind="sendRequest.BirthdayDay" />
                            <div class="form-text">Leave day empty for the full month.</div>
                        </div>
                    }
                    else if (sendRequest.GroupBasis == "location")
                    {
                        <div class="col-md-5">
                            <label class="form-label">City or Country</label>
                            <input class="form-control" @bind="sendRequest.LocationQuery" placeholder="Tel Aviv, Israel, London..." />
                        </div>
                    }
                    else if (sendRequest.GroupBasis == "language")
                    {
                        <div class="col-md-2">
                            <label class="form-label">Language</label>
                            <input class="form-control" @bind="sendRequest.Language" placeholder="en, he, ar..." />
                        </div>
                    }
                }
                <div class="col-md-12">
                    <label class="form-label">Message</label>
                    <textarea class="form-control" rows="3" @bind="sendRequest.Message"></textarea>
                </div>
                <div class="col-md-12">
                    <label class="form-label">Channels</label>
                    <div class="d-flex flex-wrap gap-3">
                        <label><input type="checkbox" class="form-check-input me-1" @bind="sendRequest.InApp" /> In-app</label>
                        <label><input type="checkbox" class="form-check-input me-1" @bind="sendRequest.Email" /> Email</label>
                        <label><input type="checkbox" class="form-check-input me-1" @bind="sendRequest.Sms" /> SMS</label>
                        <label><input type="checkbox" class="form-check-input me-1" @bind="sendRequest.Push" /> Push</label>
                        <label><input type="checkbox" class="form-check-input me-1" @bind="sendRequest.WebPush" /> Web Push</label>
                        <label><input type="checkbox" class="form-check-input me-1" @bind="sendRequest.Telegram" /> Telegram</label>
                    </div>
                    <div class="form-text">Non in-app channels are queued for the notification service delivery processor.</div>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Schedule For</label>
                    <input type="datetime-local" class="form-control" @bind="sendRequest.ScheduledFor" />
                </div>
            </div>
        </div>
        <div class="card-footer text-end">
            <button class="btn btn-primary" @onclick="SendNotification" disabled="@(isSending || !canSendNotifications)">
                @if (isSending)
                {
                    <span class="spinner-border spinner-border-sm me-2"></span>
                }
                <i class="fas fa-paper-plane me-1"></i> Queue Notification
            </button>
        </div>
    </div>

    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <strong>Recent Notifications</strong>
            <button class="btn btn-sm btn-outline-secondary" @onclick="LoadRecentNotifications">
                <i class="fas fa-sync"></i> Refresh
            </button>
        </div>
        <div class="card-body">
            @if (isLoading)
            {
                <div class="text-center py-5">
                    <div class="spinner-border text-primary" role="status"></div>
                </div>
            }
            else if (recentNotifications?.Any() == true)
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead>
                            <tr>
                                <th>Created</th>
                                <th>User</th>
                                <th>Type</th>
                                <th>Title</th>
                                <th>Read</th>
                                <th>Delivery</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var notification in recentNotifications)
                            {
                                <tr>
                                    <td>@notification.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                                    <td>
                                        <div>@(notification.UserEmail ?? notification.UserId.ToString())</div>
                                        <small class="text-muted">@notification.UserId</small>
                                    </td>
                                    <td><span class="badge bg-secondary">@notification.Type</span></td>
                                    <td>
                                        <strong>@notification.Title</strong>
                                        <div class="small text-muted">@notification.Message</div>
                                    </td>
                                    <td>
                                        <span class="badge bg-@(notification.IsRead ? "success" : "warning")">
                                            @(notification.IsRead ? "Read" : "Unread")
                                        </span>
                                    </td>
                                    <td>
                                        <span class="badge bg-info">@notification.PendingDeliveries pending</span>
                                        <span class="badge bg-success">@notification.SentDeliveries sent</span>
                                        <span class="badge bg-danger">@notification.FailedDeliveries failed</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-info mb-0">No notifications found.</div>
            }
        </div>
    </div>
</div>

@code {
    private SendAdminNotificationRequest sendRequest = new();
    private List<HouseDto> houses = new();
    private IReadOnlyCollection<AdminNotificationDto>? recentNotifications;
    private bool isLoading = true;
    private bool isSending;
    private string? message;
    private string messageType = "success";
    private string? houseTargetId;
    private string? lotteryTargetId;
    private bool canSendNotifications;

    protected override async Task OnInitializedAsync()
    {
        canSendNotifications = await PermissionService.HasPermissionAsync(AdminPermissionNames.NotificationsSend) ||
            await PermissionService.HasPermissionAsync(AdminPermissionNames.SettingsManage);
        await LoadHouses();
        await LoadRecentNotifications();
    }

    private async Task LoadHouses()
    {
        try
        {
            var result = await HousesService.GetHousesAsync(1, 1000, null, null);
            houses = result.Items.ToList();
        }
        catch (Exception ex)
        {
            SetMessage(ex.Message, "danger");
        }
    }

    private async Task LoadRecentNotifications()
    {
        isLoading = true;
        try
        {
            recentNotifications = await MessagingService.GetRecentNotificationsAsync();
        }
        catch (Exception ex)
        {
            SetMessage(ex.Message, "danger");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task SendNotification()
    {
        isSending = true;
        try
        {
            sendRequest.HouseId = Guid.TryParse(houseTargetId, out var houseId) ? houseId : null;
            sendRequest.LotteryHouseId = Guid.TryParse(lotteryTargetId, out var lotteryHouseId) ? lotteryHouseId : null;

            var result = await MessagingService.QueueNotificationAsync(sendRequest);
            var target = result.RecipientCount == 1 ? result.UserEmail : $"{result.RecipientCount} recipients";
            SetMessage($"Queued notification {result.NotificationId} for {target} via {string.Join(", ", result.QueuedChannels)}.", "success");
            sendRequest = new SendAdminNotificationRequest();
            houseTargetId = null;
            lotteryTargetId = null;
            await LoadRecentNotifications();
        }
        catch (Exception ex)
        {
            SetMessage(ex.Message, "danger");
        }
        finally
        {
            isSending = false;
        }
    }

    private void SetMessage(string value, string type)
    {
        message = value;
        messageType = type;
    }
}
