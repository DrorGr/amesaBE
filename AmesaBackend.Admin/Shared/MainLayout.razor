@inherits LayoutComponentBase
@using AmesaBackend.Admin.Components
@inject IAdminAuthService AuthService
@inject IAdminPermissionService PermissionService
@inject NavigationManager Navigation

@{
    var currentPath = Navigation.Uri.Replace(Navigation.BaseUri, "").TrimStart('/');
    var isLoginPage = currentPath.Equals("login", StringComparison.OrdinalIgnoreCase) || 
                      currentPath.Equals("admin/login", StringComparison.OrdinalIgnoreCase);
    
    // Safely check authentication - never throw exceptions during render
    bool isAuthenticated = false;
    if (!isLoginPage)
    {
        try
        {
            isAuthenticated = AuthService.IsAuthenticated();
        }
        catch
        {
            // If authentication check fails, assume not authenticated
            isAuthenticated = false;
        }
    }
}

@if (isLoginPage)
{
    @Body
}
else if (!isAuthenticated)
{
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="card">
                    <div class="card-body">
                        <h3 class="card-title text-center mb-4">
                            <i class="fas fa-lock"></i> Admin Access Required
                        </h3>
                        <p class="text-center text-muted">Please log in to access the admin panel.</p>
                        <div class="text-center">
                            <a href="login" class="btn btn-primary">
                                <i class="fas fa-sign-in-alt"></i> Login
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="container-fluid">
        <div class="row">
            <nav class="col-md-2 d-md-block sidebar">
                <div class="position-sticky pt-3">
                    <div class="text-center mb-4">
                        <h4><i class="fas fa-crown"></i> Amesa Admin</h4>
                        @{
                            var adminEmail = "";
                            try
                            {
                                adminEmail = AuthService.GetCurrentAdminEmail() ?? "";
                            }
                            catch
                            {
                                adminEmail = "";
                            }
                        }
                        @if (!string.IsNullOrEmpty(adminEmail))
                        {
                            <small class="d-block mt-2">@adminEmail</small>
                        }
                        <div class="mt-3">
                            <AmesaBackend.Admin.Components.DatabaseSelector />
                        </div>
                    </div>
                    <hr />
                    <ul class="nav flex-column">
                        @if (Can(AdminPermissionNames.DashboardRead))
                        {
                            <li class="nav-item">
                                <a class="nav-link" href="">
                                    <i class="fas fa-tachometer-alt me-2"></i> Dashboard
                                </a>
                            </li>
                        }
                    </ul>
                    <hr />
                    <h6 class="sidebar-heading px-3 mt-4 mb-1 text-muted">
                        <span>Management</span>
                    </h6>
                    <ul class="nav flex-column">
                        @if (Can(AdminPermissionNames.HousesRead))
                        {
                            <li class="nav-item">
                                <a class="nav-link" href="houses">
                                    <i class="fas fa-home me-2"></i> Houses
                                </a>
                            </li>
                        }
                        @if (Can(AdminPermissionNames.UsersRead))
                        {
                            <li class="nav-item">
                                <a class="nav-link" href="users">
                                    <i class="fas fa-users me-2"></i> Users
                                </a>
                            </li>
                        }
                        @if (Can(AdminPermissionNames.TicketsRead))
                        {
                            <li class="nav-item">
                                <a class="nav-link" href="tickets">
                                    <i class="fas fa-ticket-alt me-2"></i> Tickets
                                </a>
                            </li>
                        }
                        @if (Can(AdminPermissionNames.DrawsRead))
                        {
                            <li class="nav-item">
                                <a class="nav-link" href="draws">
                                    <i class="fas fa-dice me-2"></i> Draws
                                </a>
                            </li>
                        }
                        @if (Can(AdminPermissionNames.PaymentsRead))
                        {
                            <li class="nav-item">
                                <a class="nav-link" href="payments">
                                    <i class="fas fa-euro-sign me-2"></i> Payments
                                </a>
                            </li>
                        }
                        @if (Can(AdminPermissionNames.TranslationsRead))
                        {
                            <li class="nav-item">
                                <a class="nav-link" href="translations">
                                    <i class="fas fa-language me-2"></i> Translations
                                </a>
                            </li>
                        }
                        @if (Can(AdminPermissionNames.SettingsManage) || Can(AdminPermissionNames.AuditRead))
                        {
                            <li class="nav-item">
                                <a class="nav-link" href="promotions">
                                    <i class="fas fa-tags me-2"></i> Promotions
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="messaging">
                                    <i class="fas fa-bullhorn me-2"></i> Messaging
                                </a>
                            </li>
                        }
                        @if (Can(AdminPermissionNames.AuditRead))
                        {
                            <li class="nav-item">
                                <a class="nav-link" href="audit">
                                    <i class="fas fa-clipboard-list me-2"></i> Audit Logs
                                </a>
                            </li>
                        }
                    </ul>
                    <hr />
                    <ul class="nav flex-column">
                        <li class="nav-item">
                            <a class="nav-link" href="logout">
                                <i class="fas fa-sign-out-alt me-2"></i> Logout
                            </a>
                        </li>
                    </ul>
                </div>
            </nav>
            <main class="col-md-10 ms-sm-auto main-content">
                @Body
            </main>
        </div>
    </div>
}

@code {
    private HashSet<string> permissions = new(StringComparer.OrdinalIgnoreCase);

    protected override async Task OnInitializedAsync()
    {
        try
        {
            if (AuthService.IsAuthenticated())
            {
                permissions = (await PermissionService.GetCurrentPermissionsAsync())
                    .ToHashSet(StringComparer.OrdinalIgnoreCase);
            }
        }
        catch
        {
            permissions = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        }
    }

    private bool Can(string permission) => permissions.Contains(permission);
}
