{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Redis": ""
  },
  "EventBridge": {
    "EventBusName": "amesa-event-bus",
    "Source": "amesa.admin-service"
  },
  "CacheConfig": {
    "RedisConnection": "",
    "InstanceName": "amesa-admin",
    "UseSSL": false
  },
  "XRay": {
    "ServiceName": "amesa-admin-service",
    "Enabled": true
  },
  "AdminSettings": {
    "Email": "admin@amesa.com",
    "Password": "Admin123!"
  },
  "ServiceHealth": {
    "ProbeTimeoutSeconds": 5,
    "PresenceWindowMinutes": 15,
    "Endpoints": {
      "auth-api": {
        "Name": "Auth API",
        "Category": "service",
        "Url": "http://amesa-auth-service:8080",
        "HealthPath": "/health"
      },
      "lottery-api": {
        "Name": "Lottery API",
        "Category": "service",
        "Url": "http://amesa-lottery-service:8080",
        "HealthPath": "/health"
      },
      "payment-api": {
        "Name": "Payment API",
        "Category": "service",
        "Url": "http://amesa-payment-service:8080",
        "HealthPath": "/health"
      },
      "notification-api": {
        "Name": "Notification API",
        "Category": "service",
